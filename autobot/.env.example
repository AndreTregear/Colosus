PORT=3000

# Database — these must match docker-compose.yml defaults
POSTGRES_USER=yaya_prod
POSTGRES_PASSWORD=yaya_s3cur3_db_2024!
POSTGRES_DB=yaya
DATABASE_URL=postgresql://yaya_prod:yaya_s3cur3_db_2024!@localhost:5432/yaya

# Redis (for Phase 2 queues)
REDIS_URL=redis://localhost:6379

# AI (DeepSeek — or any OpenAI-compatible API)
AI_API_KEY=sk-your-deepseek-api-key
AI_BASE_URL=https://api.deepseek.com/v1
AI_MODEL=deepseek-chat
AI_MAX_TOKENS=1024

# ── Yaya voice infrastructure (see ../INFRA.md). All four bearer-protected. ──
# LLM (vLLM, Qwen3.6-35B-A3B-AWQ-4bit)
YAYA_LLM_URL=http://localhost:8000/v1
YAYA_LLM_KEY=welcometothepresent
YAYA_LLM_MODEL=cyankiwi/Qwen3.6-35B-A3B-AWQ-4bit
# ASR REST (Speaches, faster-whisper-large-v3-turbo)
YAYA_ASR_URL=http://localhost:8001
YAYA_ASR_KEY=welcometothepresent
YAYA_ASR_MODEL=deepdml/faster-whisper-large-v3-turbo-ct2
# ASR streaming (live calls, Silero VAD + faster-whisper)
YAYA_ASR_WS_URL=ws://localhost:8003
YAYA_ASR_WS_KEY=welcometothepresent
# TTS (Kokoro-FastAPI)
YAYA_TTS_URL=http://localhost:8002
YAYA_TTS_KEY=welcometothepresent
YAYA_TTS_VOICE=ef_dora
YAYA_TTS_MODEL=kokoro

# Auth (REQUIRED — generate secret with: openssl rand -base64 32)
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=https://yaya.sh

# Object Storage (S3 / MinIO — REQUIRED, must match docker-compose.yml)
MINIO_ROOT_USER=yaya_s3_admin
MINIO_ROOT_PASSWORD=yaya_s3cur3_m1n10_2024!
S3_ACCESS_KEY=yaya_s3_admin
S3_SECRET_KEY=yaya_s3cur3_m1n10_2024!

# Auto-create admin user on first startup (CHANGE THESE in production!)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme
ADMIN_NAME=Admin

# Queue
QUEUE_CONCURRENCY=10
QUEUE_MAX_RETRIES=3
QUEUE_RETRY_DELAY_MS=5000

# Business defaults (can be overridden per-tenant via API)
BUSINESS_NAME=Mi Negocio
YAPE_NUMBER=938438401
YAPE_NAME=Juan Perez
BUSINESS_CURRENCY=PEN

# ── yaya_pay (Android-phone-as-payment-gateway) ──
# https://github.com/AndreTregear/yaya_pay
# Bootstrap once on the phone, then reach it over USB (`adb forward tcp:8080 tcp:8080`)
# or its public relay tunnel.
YAYAPAY_BASE_URL=
YAYAPAY_API_KEY=
# Webhook signing secret. Returned ONCE when you POST /v1/webhook_endpoints
# with url=https://<your-host>/api/v1/webhooks/yayapay
YAYAPAY_WEBHOOK_SECRET=
# Default wallet to charge (YAPE | PLIN | NEQUI | DAVIPLATA | PIX_NUBANK | ...)
YAYAPAY_DEFAULT_WALLET=YAPE
# Phone / handle the customer pays into. Defaults to YAPE_NUMBER.
YAYAPAY_RECIPIENT_ID=
# Onboarding charge in centimos (2900 = S/ 29.00).
YAYAPAY_ONBOARDING_AMOUNT=2900
YAYAPAY_INTENT_TTL_MIN=30

# ── OSS Service Integrations (optional — services degrade gracefully if unavailable) ──

# Lago — billing, subscriptions, usage metering (https://getlago.com)
LAGO_API_URL=http://lago-api:3000
LAGO_API_KEY=

# Cal.com — appointments, scheduling, availability
CALCOM_API_URL=http://calcom:3000
CALCOM_API_KEY=

# Metabase — BI dashboards, saved questions, scheduled reports
METABASE_API_URL=http://metabase:3000
METABASE_API_KEY=

# InvoiceShelf — invoicing
INVOICESHELF_API_URL=http://invoiceshelf:9000
INVOICESHELF_API_KEY=

# AI Observability — Langfuse (optional, get free account at langfuse.com)
# Both keys must be set to activate tracing
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com
