# =============================================================================
# Yaya Platform — Environment Configuration
# =============================================================================
# Copy to .env and customize all values marked "changeme".
#
#   cp .env.example .env
#   # Edit .env with your values
#   docker compose -f docker-compose.prod.yml --env-file .env up -d
# =============================================================================

# ── Host ─────────────────────────────────────────────────────────────────────
HOST_IP=localhost

# ── Main Database (PostgreSQL 16) ────────────────────────────────────────────
POSTGRES_USER=yaya
POSTGRES_PASSWORD=changeme
POSTGRES_DB=yaya
POSTGRES_PORT=5432

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_PORT=6379

# ── Object Storage (MinIO) ──────────────────────────────────────────────────
MINIO_ROOT_USER=yaya_s3
MINIO_ROOT_PASSWORD=changeme
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_PUBLIC_URL=http://localhost:9000

# ── Autobot (AI Agent + Web Dashboard) ──────────────────────────────────────
AUTOBOT_PORT=3000
ADMIN_EMAIL=admin@yaya.sh
ADMIN_PASSWORD=changeme
ADMIN_NAME=Admin

# OpenClaw — AI agent backend (skills + MCP servers)
OPENCLAW_API_URL=http://localhost:3100/api/v1
OPENCLAW_API_KEY=

# AI — points to GPU host running vLLM (Qwen3.5-27B)
AI_API_KEY=megustalaia
AI_BASE_URL=http://localhost:8000/v1
AI_MODEL=qwen3.5-27b
AI_MAX_TOKENS=1024

# Voice — GPU host running Whisper + Kokoro TTS
WHISPER_URL=http://localhost:9100
TTS_URL=http://localhost:9200
TTS_API_KEY=megustalaia

# Auth (REQUIRED — generate with: openssl rand -base64 32)
BETTER_AUTH_SECRET=changeme
BETTER_AUTH_URL=https://your-domain.com

# Queue
QUEUE_CONCURRENCY=10
QUEUE_MAX_RETRIES=3
QUEUE_RETRY_DELAY_MS=5000

# Business defaults (overridden per-tenant via dashboard)
BUSINESS_NAME=Mi Negocio
BUSINESS_CURRENCY=PEN
YAPE_NUMBER=
YAPE_NAME=
PAYMENT_METHODS=yape,plin,bank_transfer

# Observability — Langfuse (optional, https://langfuse.com)
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ── Lago Billing ────────────────────────────────────────────────────────────
LAGO_VERSION=v1.44.0
LAGO_DB_USER=lago
LAGO_DB_PASSWORD=lago_s3cur3
LAGO_DB_NAME=lago_db
LAGO_API_PORT=3001
LAGO_FRONT_PORT=8080
LAGO_API_KEY=
LAGO_SECRET_KEY_BASE=changeme_generate_with_openssl
LAGO_RSA_PRIVATE_KEY=
LAGO_ENCRYPTION_PRIMARY_KEY=changeme
LAGO_ENCRYPTION_DETERMINISTIC_KEY=changeme
LAGO_ENCRYPTION_KEY_DERIVATION_SALT=changeme

# ── InvoiceShelf ─────────────────────────────────────────────────────────────
INVOICESHELF_PORT=8090
INVOICESHELF_APP_KEY=base64:changeme
INVOICESHELF_URL=http://localhost:8090

# ── Cal.com Scheduling ──────────────────────────────────────────────────────
CALCOM_PORT=3002
CALCOM_DB_USER=calcom
CALCOM_DB_PASSWORD=calcom_s3cur3
CALCOM_DB_NAME=calcom_db
CALCOM_NEXTAUTH_SECRET=changeme
CALCOM_ENCRYPTION_KEY=changeme
CALCOM_PUBLIC_URL=http://localhost:3002
CALCOM_API_KEY=
CALCOM_LICENSE_KEY=

# ── Metabase Analytics ──────────────────────────────────────────────────────
METABASE_PORT=3003
METABASE_DB_NAME=metabase_db
METABASE_DB_USER=metabase
METABASE_DB_PASSWORD=metabase_s3cur3
METABASE_TIMEZONE=America/Lima
METABASE_API_KEY=
MB_EMAIL_SMTP_HOST=
MB_EMAIL_SMTP_PORT=

# ── Phase 2: ERPNext (uncomment in docker-compose.prod.yml) ─────────────────
# ERPNEXT_DB_ROOT_PASSWORD=changeme
# ERPNEXT_DB_NAME=erpnext
# ERPNEXT_DB_USER=erpnext
# ERPNEXT_DB_PASSWORD=changeme

# ── Phase 2: Karrio Shipping (uncomment in docker-compose.prod.yml) ─────────
# KARRIO_API_PORT=5002
# KARRIO_DASHBOARD_PORT=3005
# KARRIO_DB_NAME=karrio
# KARRIO_DB_USER=karrio
# KARRIO_DB_PASSWORD=changeme
# KARRIO_PUBLIC_URL=http://localhost:5002

