# =============================================================================
# Yaya Platform — Environment Configuration
# =============================================================================
# Copy to .env and customize values marked CHANGEME / empty.
#
#   cp .env.example .env
#   vim .env
#   ./start.sh
#
# Secrets auto-generated by start.sh if left blank:
#   BETTER_AUTH_SECRET, LAGO_SECRET, LAGO_ENC_*
# =============================================================================

# ── Server ──────────────────────────────────────────────────────────────────
PORT=3000
LOG_LEVEL=info                          # debug | info | warn | error

# ── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_USER=yaya_prod
POSTGRES_PASSWORD=CHANGEME              # Strong password for production
POSTGRES_DB=yaya
DATABASE_URL=postgresql://yaya_prod:CHANGEME@localhost:5432/yaya

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth (REQUIRED) ────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
# If left empty, start.sh will auto-generate one.
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=https://cx.yaya.sh      # Public URL of your autobot dashboard

# ── Admin User (created on first startup) ───────────────────────────────────
ADMIN_EMAIL=admin@yaya.sh
ADMIN_PASSWORD=CHANGEME
ADMIN_NAME=Admin

# ── AI — vLLM (local GPU) ──────────────────────────────────────────────────
AI_API_KEY=megustalaia                  # vLLM --api-key value
AI_BASE_URL=http://localhost:8000/v1
AI_MODEL=qwen3.5-27b
AI_MAX_TOKENS=1024

# Disable thinking for faster responses (optional)
AI_EXTRA_BODY={"chat_template_kwargs":{"enable_thinking":false}}

# ── Whisper STT (local GPU) ────────────────────────────────────────────────
WHISPER_BASE_URL=http://localhost:9300/v1
WHISPER_API_KEY=megustalaia
WHISPER_MODEL=large-v3-turbo

# ── Vision ──────────────────────────────────────────────────────────────────
VISION_BASE_URL=http://localhost:8000/v1
VISION_API_KEY=megustalaia
VISION_MODEL=qwen3.5-27b

# ── Object Storage (MinIO) ─────────────────────────────────────────────────
MINIO_ROOT_USER=yaya_s3_admin
MINIO_ROOT_PASSWORD=CHANGEME
S3_ACCESS_KEY=yaya_s3_admin             # Same as MINIO_ROOT_USER
S3_SECRET_KEY=CHANGEME                  # Same as MINIO_ROOT_PASSWORD
S3_ENDPOINT=localhost
S3_PORT=9000

# ── Queue (BullMQ) ─────────────────────────────────────────────────────────
QUEUE_CONCURRENCY=10
QUEUE_MAX_RETRIES=3
QUEUE_RETRY_DELAY_MS=5000

# ── Business Defaults (overridden per-tenant) ──────────────────────────────
BUSINESS_NAME=Mi Negocio
BUSINESS_CURRENCY=PEN

# ── OpenClaw Agent ──────────────────────────────────────────────────────────
OPENCLAW_BIN=/home/yaya/.npm-global/bin/openclaw
OPENCLAW_AGENT=yaya-platform

# ── Cal.com (Scheduling) ───────────────────────────────────────────────────
CALCOM_API_URL=http://localhost:3002
CALCOM_API_KEY=                         # Get from Cal.com admin → API Keys
CALCOM_DB_USER=calcom
CALCOM_DB_PASS=calcom_s3cur3
CALCOM_SECRET=                          # Auto-generated if empty
CALCOM_ENCRYPTION_KEY=                  # 32+ chars, auto-generated if empty
CALCOM_URL=http://localhost:3002        # Public URL

# ── Lago (Billing) ─────────────────────────────────────────────────────────
LAGO_API_URL=http://localhost:3010
LAGO_API_KEY=                           # Get from Lago dashboard → Developers
LAGO_SECRET=                            # Auto-generated by start.sh
LAGO_RSA_PRIVATE_KEY=                   # Optional: for webhooks signature
LAGO_ENC_PRIMARY=                       # Auto-generated by start.sh
LAGO_ENC_DETERMINISTIC=                 # Auto-generated by start.sh
LAGO_ENC_SALT=                          # Auto-generated by start.sh

# ── Metabase (Analytics) ───────────────────────────────────────────────────
METABASE_API_URL=http://localhost:3003
METABASE_API_KEY=                       # Get from Metabase admin → API Keys

# ── vLLM Model Path ────────────────────────────────────────────────────────
MODEL_PATH=/home/yaya/models/Qwen3.5-27B-AWQ

# ── Observability (optional) ───────────────────────────────────────────────
# Langfuse — LLM tracing (https://langfuse.com)
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
