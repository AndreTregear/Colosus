# Lago Billing configuration
# Full reference: https://docs.getlago.com/guide/self-hosting/docker

LAGO_VERSION=v1.44.0
LAGO_API_PORT=3002
LAGO_FRONT_PORT=8080
LAGO_API_URL=http://localhost:3002

POSTGRES_USER=lago
POSTGRES_PASSWORD=lago
POSTGRES_DB=lago

# Required secrets (generate with: openssl rand -hex 64)
SECRET_KEY_BASE=
LAGO_RSA_PRIVATE_KEY=
ENCRYPTION_PRIMARY_KEY=
ENCRYPTION_DETERMINISTIC_KEY=
ENCRYPTION_KEY_DERIVATION_SALT=
