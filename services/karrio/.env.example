# Karrio Shipping API configuration
# Full reference: https://docs.karrio.io/

KARRIO_TAG=latest
KARRIO_API_PORT=5002
KARRIO_DASHBOARD_PORT=3005

DATABASE_USER=karrio
DATABASE_PASSWORD=karrio
DATABASE_NAME=karrio

DEBUG_MODE=False

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme

# Public URL (for dashboard to reach API)
KARRIO_PUBLIC_URL=http://localhost:5002

# Optional: carrier API keys
# UPS_CLIENT_ID=
# FEDEX_API_KEY=
# DHL_API_KEY=
