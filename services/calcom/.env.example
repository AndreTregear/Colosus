# Cal.com configuration
# Full reference: https://cal.com/docs/self-hosting/docker

POSTGRES_USER=calcom
POSTGRES_PASSWORD=calcom
POSTGRES_DB=calendso
CALCOM_PORT=3000

# Required secrets (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=
CALENDSO_ENCRYPTION_KEY=

# Public URLs
NEXT_PUBLIC_WEBAPP_URL=http://localhost:3000
NEXT_PUBLIC_API_V2_URL=http://localhost:3000/api/v2

# Optional: License key for enterprise features
# CALCOM_LICENSE_KEY=

# Optional: Email (SMTP)
# EMAIL_FROM=noreply@example.com
# EMAIL_SERVER_HOST=smtp.example.com
# EMAIL_SERVER_PORT=587
# EMAIL_SERVER_USER=
# EMAIL_SERVER_PASSWORD=
