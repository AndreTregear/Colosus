{
  "$schema": "https://openclaw.dev/schemas/config/v1.json",
  "agent": {
    "name": "Yaya",
    "version": "1.0.0",
    "description": "AI business assistant for Latin American small businesses",
    "personality": "./SOUL.md"
  },

  "channel": {
    "type": "whatsapp",
    "dmPolicy": "open",
    "allowFrom": ["*"],
    "config": {
      "whatsappApiUrl": "${WHATSAPP_API_URL}",
      "whatsappApiToken": "${WHATSAPP_API_TOKEN}",
      "whatsappPhoneNumberId": "${WHATSAPP_PHONE_NUMBER_ID}",
      "businessName": "${BUSINESS_NAME}",
      "welcomeMessage": "Hola! Bienvenido a ${BUSINESS_NAME}. Soy Yaya, tu asistente virtual. ¿En qué puedo ayudarte?",
      "offlineMessage": "Gracias por escribirnos. En este momento estamos fuera de horario. Te responderemos apenas abramos. ¡Gracias por tu paciencia!"
    }
  },

  "inference": {
    "provider": "openai-compatible",
    "model": "qwen3.5-27b",
    "endpoint": "http://localhost:8000/v1",
    "apiKey": "${VLLM_API_KEY:-none}",
    "parameters": {
      "maxTokens": 4096,
      "temperature": 0.7,
      "topP": 0.9
    }
  },

  "skills": [
    {
      "name": "yaya-sales",
      "path": "../../skills/yaya-sales/SKILL.md",
      "enabled": true,
      "priority": 1
    },
    {
      "name": "yaya-payments",
      "path": "../../skills/yaya-payments/SKILL.md",
      "enabled": true,
      "priority": 2
    },
    {
      "name": "yaya-appointments",
      "path": "../../skills/yaya-appointments/SKILL.md",
      "enabled": true,
      "priority": 3
    },
    {
      "name": "yaya-escalation",
      "path": "../../skills/yaya-escalation/SKILL.md",
      "enabled": true,
      "priority": 4
    },
    {
      "name": "yaya-tax",
      "path": "../../skills/yaya-tax/SKILL.md",
      "enabled": true,
      "priority": 5
    },
    {
      "name": "yaya-crm",
      "path": "../../skills/yaya-crm/SKILL.md",
      "enabled": true,
      "priority": 6
    },
    {
      "name": "yaya-followup",
      "path": "../../skills/yaya-followup/SKILL.md",
      "enabled": true,
      "priority": 7
    },
    {
      "name": "yaya-analytics",
      "path": "../../skills/yaya-analytics/SKILL.md",
      "enabled": true,
      "priority": 8
    }
  ],

  "mcpServers": {
    "erpnext-mcp": {
      "transport": "stdio",
      "command": "node",
      "args": ["../../mcp-servers/erpnext-mcp/dist/index.js"],
      "env": {
        "ERPNEXT_URL": "${ERPNEXT_URL:-http://localhost:8080}",
        "ERPNEXT_API_KEY": "${ERPNEXT_API_KEY}",
        "ERPNEXT_API_SECRET": "${ERPNEXT_API_SECRET}"
      }
    },
    "appointments-mcp": {
      "transport": "stdio",
      "command": "node",
      "args": ["../../mcp-servers/appointments-mcp/dist/index.js"],
      "env": {
        "APPOINTMENTS_DATABASE_URL": "${DATABASE_URL:-postgresql://localhost:5432/appointments}",
        "BUSINESS_TIMEZONE": "${BUSINESS_TIMEZONE:-America/Lima}",
        "WHATSAPP_API_URL": "${WHATSAPP_API_URL}",
        "WHATSAPP_API_TOKEN": "${WHATSAPP_API_TOKEN}",
        "CAL_COM_API_URL": "${CAL_COM_API_URL:-http://localhost:3000/api/v1}",
        "CAL_COM_API_KEY": "${CAL_COM_API_KEY}",
        "DEPOSIT_EXPIRY_HOURS": "${DEPOSIT_EXPIRY_HOURS:-2}"
      }
    },
    "invoicing-mcp": {
      "transport": "stdio",
      "command": "node",
      "args": ["../../mcp-servers/invoicing-mcp/dist/index.js"],
      "env": {
        "SUNAT_SOL_USER": "${SUNAT_SOL_USER}",
        "SUNAT_SOL_PASSWORD": "${SUNAT_SOL_PASSWORD}",
        "SUNAT_RUC": "${SUNAT_RUC}",
        "SUNAT_CERTIFICATE_PATH": "${SUNAT_CERTIFICATE_PATH}",
        "SUNAT_API_URL": "${SUNAT_API_URL}"
      }
    },
    "forex-mcp": {
      "transport": "stdio",
      "command": "node",
      "args": ["../../mcp-servers/forex-mcp/dist/index.js"],
      "env": {
        "BASE_CURRENCY": "${BASE_CURRENCY:-PEN}"
      }
    },
    "payments-mcp": {
      "transport": "stdio",
      "command": "node",
      "args": ["../../mcp-servers/payments-mcp/dist/index.js"],
      "env": {
        "YAPE_NUMBER": "${YAPE_NUMBER}",
        "YAPE_NAME": "${YAPE_NAME}",
        "PAYMENT_METHODS": "${PAYMENT_METHODS:-yape,plin,bank_transfer}",
        "PAYMENT_VALIDATION_WEBHOOK": "${PAYMENT_VALIDATION_WEBHOOK:-http://localhost:3002}"
      }
    },
    "crm-mcp": {
      "transport": "stdio",
      "command": "node",
      "args": ["../../mcp-servers/crm-mcp/dist/index.js"],
      "env": {
        "SUPABASE_URL": "${SUPABASE_URL:-http://localhost:54321}",
        "SUPABASE_ANON_KEY": "${SUPABASE_ANON_KEY}",
        "SUPABASE_SERVICE_KEY": "${SUPABASE_SERVICE_KEY}"
      }
    },
    "whatsapp-mcp": {
      "transport": "stdio",
      "command": "node",
      "args": ["../../mcp-servers/postgres-mcp/dist/index.js"],
      "env": {
        "DATABASE_URL": "${DATABASE_URL:-postgresql://localhost:5432/yaya}",
        "SCHEMA": "whatsapp"
      }
    }
  },

  "security": {
    "policyFile": "../nemoclaw/policy.yaml",
    "localOnly": true,
    "stripPii": true
  },

  "locale": {
    "primaryLanguage": "es",
    "secondaryLanguage": "en",
    "timezone": "${BUSINESS_TIMEZONE:-America/Lima}",
    "currency": "${CURRENCY:-PEN}",
    "dateFormat": "DD/MM/YYYY",
    "timeFormat": "12h"
  },

  "escalation": {
    "ownerPhone": "${OWNER_PHONE}",
    "refundThreshold": 100,
    "triggers": [
      "refund_over_threshold",
      "complaint",
      "custom_pricing_request",
      "emergency",
      "repeated_no_show"
    ]
  },

  "businessHours": {
    "timezone": "${BUSINESS_TIMEZONE:-America/Lima}",
    "schedule": {
      "monday":    { "open": "09:00", "close": "18:00" },
      "tuesday":   { "open": "09:00", "close": "18:00" },
      "wednesday": { "open": "09:00", "close": "18:00" },
      "thursday":  { "open": "09:00", "close": "18:00" },
      "friday":    { "open": "09:00", "close": "18:00" },
      "saturday":  { "open": "09:00", "close": "13:00" },
      "sunday":    null
    }
  }
}
