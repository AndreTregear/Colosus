# Yaya Platform Environment
# Copy to .env and customize — or run infra/scripts/setup.sh to auto-generate

# ── Host ──
HOST_IP=localhost

# ── Main Database (PostgreSQL) ──
POSTGRES_USER=yaya
POSTGRES_PASSWORD=changeme
POSTGRES_DB=yaya

# ── Lago Database ──
LAGO_DB_USER=lago
LAGO_DB_PASSWORD=lago_s3cur3
LAGO_DB_NAME=lago_db

# ── Object Storage (MinIO) ──
MINIO_ROOT_USER=yaya_s3
MINIO_ROOT_PASSWORD=changeme

# ── LLM (vLLM + Qwen3.5-27B) ──
MODEL_PATH=/home/yaya/models/Qwen3.5-27B-AWQ
LLM_API_KEY=megustalaia

# ── Whisper ──
WHISPER_MODEL=large-v3-turbo
WHISPER_LANGUAGE=es

# ── ERPNext ──
ERPNEXT_URL=http://localhost:8080
ERPNEXT_API_KEY=
ERPNEXT_API_SECRET=

# ── Lago Billing ──
LAGO_API_URL=http://localhost:3001
LAGO_API_KEY=
LAGO_SECRET_KEY_BASE=changeme_generate_with_setup_sh
LAGO_RSA_PRIVATE_KEY=
LAGO_ENCRYPTION_PRIMARY_KEY=changeme
LAGO_ENCRYPTION_DETERMINISTIC_KEY=changeme
LAGO_ENCRYPTION_KEY_DERIVATION_SALT=changeme

# ── Supabase (Atomic CRM) ──
SUPABASE_DB_USER=supabase_admin
SUPABASE_DB_PASSWORD=changeme
CRM_DB_NAME=crm_db
SUPABASE_JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9
SUPABASE_REALTIME_SECRET=changeme_at_least_64_characters_long_for_production_use_please

# ── Authentication ──
BETTER_AUTH_SECRET=changeme

# ── Business Defaults ──
BUSINESS_NAME=Mi Negocio
BUSINESS_CURRENCY=PEN
YAPE_NUMBER=938438401
YAPE_NAME=Juan Perez
PAYMENT_METHODS=yape,plin,bank_transfer
